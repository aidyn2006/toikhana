# Production reverse proxy for toikhan.kz
# Serves the built SPA (frontend/dist) and forwards API + dynamic sitemap to the backend.
# Copy/adapt this into your nginx (or Caddy/Traefik) that terminates the toikhan.kz domain.

upstream toikhana_backend {
    server backend:8080;   # change to 127.0.0.1:8080 if backend runs on the host
}

server {
    listen 80;
    server_name toikhan.kz www.toikhan.kz;

    root /usr/share/nginx/html;   # where frontend/dist is deployed
    index index.html;

    # robots.txt is shipped as a static file in dist/ — served directly by try_files below.

    # Dynamic sitemap generated by Spring Boot (covers all cities, toikhanas, blog posts)
    location = /sitemap.xml {
        proxy_pass http://toikhana_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Backend API and uploaded media
    location /api/ {
        proxy_pass http://toikhana_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    location /uploads/ {
        proxy_pass http://toikhana_backend;
        proxy_set_header Host $host;
    }

    # SPA fallback — every other route returns index.html (React Router handles it)
    location / {
        try_files $uri $uri/ /index.html;
    }
}
